# Arbitrum RPC (WebSocket required for block subscriptions)
RPC_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
RPC_HTTP_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Bot wallet private key (NO 0x prefix)
PRIVATE_KEY=your_private_key_here

# Deployed MobiusExecutor contract address
EXECUTOR_ADDRESS=0x...

# WETH address on Arbitrum
WETH_ADDRESS=0x82aF49447D8a07e3bd95BD0d56f35241523fBab1

# Uniswap V2 Factory addresses on Arbitrum
# SushiSwap
SUSHI_FACTORY=0xc35DADB65012eC5796536bD9864eD8773aBc74C4
SUSHI_INIT_CODE_HASH=0xe18a34eb0e04b04f7a0ac29a6e80748dca96319b42c54d679cb821dca90c6303

# Camelot
CAMELOT_FACTORY=0x6EcCab422D763aC031210895C81787E87B43A652

# Minimum profit in Wei to execute (e.g., 0.001 ETH = 1000000000000000)
MIN_PROFIT_WEI=500000000000000

# Max hops in arbitrage cycle
MAX_HOPS=4

# Gas settings
MAX_GAS_PRICE_GWEI=0.5
GAS_LIMIT=500000

# Logging level
RUST_LOG=mobius_arb=info
